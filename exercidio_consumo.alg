Algoritmo "consumo"
Var
distancia, combustivelGasto, media: real
Inicio
escreva("Digite a distância percorrida (em KM) ")
leia(distancia)
escreva("Digite o combustível gasto nesta corrida ")
leia(combustivelGasto)
media <- distancia / combustivelGasto
escreval("Consumo médio: ", media:3:3)
Fimalgoritmo
